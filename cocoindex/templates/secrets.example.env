# CocoIndex Secrets（API キー専用）
#
# このファイルは ~/.config/cocoindex/secrets.env に自動コピーされます。
# 既存の secrets.env は上書きしないので、API キーを設定してください。
#
# 通常の設定値（DB URL、provider、model、chunk size 等）は config.toml で管理します。
# 環境変数で上書きしたい場合のみここに記入してください。

# Voyage AI（既定の embedding provider）
VOYAGE_API_KEY=

# OpenAI（EMBEDDING_PROVIDER=openai 利用時）
# OPENAI_API_KEY=
