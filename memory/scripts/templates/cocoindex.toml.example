# recording スキル専用 cocoindex 設定
#
# このファイルは ~/.config/memory/cocoindex.toml に自動コピーされます。
# 既存の cocoindex.toml は上書きされません（自由に編集してください）。
#
# 優先順位（強い順）: 環境変数 > このファイル > main_memory.py の既定値
# 環境変数で上書きする場合は MEMORIES_* プレフィックスを使用（例: MEMORIES_CHUNK_SIZE=1500）。
#
# API キーは共通の ~/.config/cocoindex/secrets.env で管理します（このファイルには書かない）。
# DB 接続先は cocoindex プラグインの ~/.config/cocoindex/config.toml [database].url を共有します。

[embedding]
# 環境変数: MEMORIES_EMBEDDING_PROVIDER
provider = "voyage"
# 環境変数: MEMORIES_EMBEDDING_MODEL
# 多言語自然文書には voyage-3-large が voyage-4-large より好成績（要約レポート系で実測）
model = "voyage-3-large"
# 環境変数: MEMORIES_EMBEDDING_DIMENSION
dimension = 1024

[chunk]
# 環境変数: MEMORIES_CHUNK_SIZE / MEMORIES_CHUNK_OVERLAP
# 評価で 1200/300 が最良（MRR 0.833）
size = 1200
overlap = 300

[index]
# 環境変数: MEMORIES_EXCLUDE（カンマ区切り）
# trashbox/下書き/隠しは精度ノイズになるため既定で除外
exclude = "trashbox/**,**/_*.md,.git/**"
