# memory プラグイン シークレット設定ファイル
# 配置先: ~/.config/recording/secrets.env
# 必須権限: chmod 600（mount-memory-share.sh は 0600 でない場合は読み込みを拒否します）
#
# このファイルは bash の `source` で読み込まれるため、シェル構文に従ってください
# （クォート不要、`KEY=value` 形式、`#` でコメント）。
# 値に空白や特殊文字を含む場合はダブルクォートで囲んでください。
#
# 設定の優先順位（高い順）:
#   1. 環境変数（既に export されていればこちらが勝つ）
#   2. このファイル
#   3. config.toml

# ----------------------------------------------------------------------------
# SMB マウント関連
# ----------------------------------------------------------------------------

# SMB 共有の user 名。mount_smbfs に //${MEMORIES_SMB_USER}@host/share の形で渡される。
# パスワードは macOS キーチェーンから自動解決されるため、ここには書かない。
MEMORIES_SMB_USER=admin

# 共有 URL を環境変数で上書きしたい場合（通常は config.toml の smb_share を使う）。
# MEMORIES_SMB_SHARE="//192.168.11.5/memory"

# ping 対象ホスト（共有 URL から抽出される値を上書きしたい場合のみ）。
# MEMORIES_SMB_PING_HOST="192.168.11.5"

# ----------------------------------------------------------------------------
# 将来用（現状未使用）
# ----------------------------------------------------------------------------

# キーチェーンを使わずに直接パスワードを渡したい場合の予約変数。
# 現状の mount-memory-share.sh は参照しないが、自前 remount_script を書く際に利用可能。
# MEMORIES_SMB_PASSWORD="..."
