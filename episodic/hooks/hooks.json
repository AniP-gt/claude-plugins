{
  "description": "episodic-recording / wiki-runner / episodic-search lifecycle hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup python3 \"${CLAUDE_PLUGIN_ROOT}/bin/session_start.py\" >/dev/null 2>&1 & disown",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup python3 \"${CLAUDE_PLUGIN_ROOT}/session/retry_pending.py\" >/dev/null 2>&1 & disown",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/session_user_prompt_submit.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/session_stop.py\""
          }
        ]
      }
    ]
  }
}
