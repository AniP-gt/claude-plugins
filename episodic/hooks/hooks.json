{
  "description": "episodic-recording / wiki-runner / episodic-search lifecycle hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup \"${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh\" >/dev/null 2>&1 & disown",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup \"${CLAUDE_PLUGIN_ROOT}/scripts/recording/retry-pending.sh\" >/dev/null 2>&1 & disown",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/session-end.sh\""
          }
        ]
      }
    ]
  }
}
