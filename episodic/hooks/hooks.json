{
  "description": "episodic-recording / wiki-runner / episodic-search lifecycle hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup \"${CLAUDE_PLUGIN_ROOT}/bin/session-start.sh\" >/dev/null 2>&1 & disown",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup \"${CLAUDE_PLUGIN_ROOT}/session/retry-pending.sh\" >/dev/null 2>&1 & disown",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/session-user-prompt-submit.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/session-stop.sh\""
          }
        ]
      }
    ]
  }
}
