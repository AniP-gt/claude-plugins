# memory プラグイン専用環境変数
#
# このファイルは ~/.config/memory/.env に自動コピーされます。
# 既存ファイルは上書きされません（必要に応じて編集してください）。
#
# 接続先 PostgreSQL は cocoindex プラグインと同じインスタンスを使用しますが、
# database 名を分けてテーブル空間を完全分離します（既定: memory）。
# setup_db.sh が CREATE DATABASE memory を冪等実行します。

# memory 専用 PostgreSQL 接続 URL。未設定なら下記既定値を使用。
MEMORY_DATABASE_URL=postgres://postgres:postgres@localhost:15432/memory

# voyage の API base / proxy 等のオプション設定（必要なら）
# VOYAGE_API_BASE=
